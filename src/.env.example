# Empowr Main Site — Environment Variables
# Copy this file to .env.local for local development.
# Never commit .env.local to git.
# All variables must also be set in Netlify > Site configuration > Environment variables.

# ------------------------------------------------------------------
# Resend (contact form email sending)
# ------------------------------------------------------------------

# Your Resend API key
# Found at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ------------------------------------------------------------------
# Contact routing
# ------------------------------------------------------------------

# General enquiries inbox — receives General Enquiry, Partnership, Media
CONTACT_EMAIL=enquiries@empowrcic.org

# Opportunities inbox — receives Work With Us enquiries
OPPORTUNITIES_EMAIL=opportunities@empowrcic.org
